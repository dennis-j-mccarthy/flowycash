generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Transaction {
  id         String   @id @default(cuid())
  userId     String   @default("default")
  name       String
  amount     Float
  type       String   // "income" or "expense"
  recurrence String   @default("none") // none, weekly, biweekly, monthly, yearly
  startDate  String   // YYYY-MM-DD
  autopay    Boolean  @default(false)
  tags       String   @default("")  // comma-separated tags
  highlight  String   @default("")  // color highlight: "", "red", "orange", "yellow", "green", "blue", "purple"
  note       String   @default("")  // user annotation
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  overrides Override[]

  @@index([userId])
}

model Override {
  id             String  @id @default(cuid())
  transactionId  String
  occurrenceDate String  // The original occurrence date YYYY-MM-DD
  name           String?
  amount         Float?
  type           String?
  deleted        Boolean @default(false)
  movedTo        String? // New date if moved YYYY-MM-DD

  transaction Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)

  @@unique([transactionId, occurrenceDate])
}

model BalanceReset {
  id     String @id @default(cuid())
  userId String @default("default")
  date   String // YYYY-MM-DD
  amount Float

  @@unique([userId, date])
  @@index([userId])
}

model Settings {
  id              String @id @default("default")
  userId          String @default("default")
  startingBalance Float  @default(0)

  @@unique([userId])
}

model MonthNote {
  id     String @id @default(cuid())
  userId String @default("default")
  month  String // YYYY-MM
  note   String @default("")

  @@unique([userId, month])
  @@index([userId])
}
